# LILYGO T-Dongle-S3 LCD configuration
# Board: ESP32-S3 USB dongle with ST7735 LCD
# Features: BLE central role for BlueAPRS bridge testing

CONFIG_IDF_TARGET_ESP32S3=y
CONFIG_IDF_TARGET="esp32s3"

# Geogram board selection
CONFIG_GEOGRAM_BOARD_TDONGLE_S3=y

# Flash - 16MB (T-Dongle-S3 has 16MB flash)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y

# CPU frequency
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=240

# No PSRAM
# CONFIG_SPIRAM is not set

# Compiler
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# FreeRTOS
CONFIG_FREERTOS_HZ=1000

# Console: USB-Serial-JTAG as the PRIMARY (and only) console. On the T-Dongle the
# UART0 pins are not exposed; /dev/ttyACM0 (USB-Serial-JTAG) is the only port, so
# make it primary — logs AND panic backtraces then land there (with UART0 primary
# they go to the unexposed pin and are invisible). No secondary console.
# The headless "STA never gets an IP" bug was NOT console-FIFO blocking (that was a
# wrong earlier theory): it was the interactive serial REPL (geogram_console
# linenoise) blocking on a floating console at boot while holding the stdio lock,
# which deadlocked the main task's next ESP_LOG and hung init right after BLE. The
# real fix is FEATURE_CONSOLE=0 (platformio.ini) — no local REPL on this headless
# iGate (telnet provides a network console). INFO logging headless is fine.
# CONFIG_ESP_CONSOLE_UART_DEFAULT is not set
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_DEFAULT_LEVEL=3

# Disable ANSI color escapes in logs
# CONFIG_LOG_COLORS is not set

# Task stacks
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=3072
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=6144
CONFIG_ESP_TIMER_TASK_STACK_SIZE=4096

# WiFi. NOTE: do NOT trim these — reducing the RX buffers drops the WPA2 EAPOL /
# DHCP packets and the STA fails to authenticate (reason 15 4-way-handshake
# timeout) or never gets an IP. Heap for the SD store is freed elsewhere instead.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=6
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=16
CONFIG_ESP_WIFI_TX_BUFFER_TYPE=1
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=16

# HTTP Server
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512
CONFIG_HTTPD_WS_SUPPORT=y

# LWIP
CONFIG_LWIP_MAX_SOCKETS=12
CONFIG_LWIP_MAX_ACTIVE_TCP=12
CONFIG_LWIP_MAX_LISTENING_TCP=6
CONFIG_LWIP_NETIF_API=y

# Partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# BLE — observer+broadcaster for BlueAPRS (no GATT, no connections)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MEM_ALLOC_MODE_INTERNAL=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
CONFIG_BT_NIMBLE_MAX_BONDS=0
CONFIG_BT_NIMBLE_ROLE_OBSERVER=y
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y
# CONFIG_BT_NIMBLE_ROLE_CENTRAL is not set
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=y
CONFIG_BT_NIMBLE_MSYS_1_BLOCK_COUNT=6
CONFIG_BT_NIMBLE_MSYS_2_BLOCK_COUNT=6
CONFIG_BT_NIMBLE_LOG_LEVEL_WARNING=y
CONFIG_BT_NIMBLE_LOG_LEVEL=2
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=4096

# ============================================================================
# ESP-Mesh-Lite Configuration (required by mesh component)
# ============================================================================
CONFIG_LWIP_IP_FORWARD=y
CONFIG_LWIP_IPV4_NAPT=y

CONFIG_BRIDGE_ENABLE=y
CONFIG_BRIDGE_DATA_FORWARDING_NETIF_SOFTAP=y
CONFIG_BRIDGE_EXTERNAL_NETIF_STATION=y
CONFIG_BRIDGE_SOFTAP_SSID="geogram"
CONFIG_BRIDGE_SOFTAP_PASSWORD="geogram1"
CONFIG_BRIDGE_SOFTAP_MAX_CONNECT_NUMBER=4
CONFIG_BRIDGE_ETHERNET_NETIF_ENABLE=n
CONFIG_BRIDGE_STATIC_DNS_SERVER_MAIN="192.168.5.1"
CONFIG_BRIDGE_STATIC_DNS_SERVER_BACKUP="192.168.5.1"

CONFIG_GEOGRAM_MESH_ENABLED=y
CONFIG_MESH_LITE_ENABLE=y
CONFIG_MESH_LITE_VENDOR_ID_0=71
CONFIG_MESH_LITE_VENDOR_ID_1=87
CONFIG_MESH_LITE_ID=103
CONFIG_MESH_LITE_MAX_ROUTER_NUMBER=3
CONFIG_MESH_LITE_MAXIMUM_LEVEL_ALLOWED=3
CONFIG_JOIN_MESH_WITHOUT_CONFIGURED_WIFI_INFO=y
CONFIG_JOIN_MESH_IGNORE_ROUTER_STATUS=y
CONFIG_DEVICE_CATEGORY="Geogram"
CONFIG_LEAF_NODE=n
CONFIG_MESH_LITE_NODE_INFO_REPORT=y

# SSH server
CONFIG_EXAMPLE_ALLOW_PASSWORD_AUTH=y
CONFIG_EXAMPLE_ALLOW_PUBLICKEY_AUTH=n
CONFIG_MBEDTLS_THREADING_C=y
CONFIG_MBEDTLS_THREADING_ALT=n
CONFIG_MBEDTLS_THREADING_PTHREAD=y

# TLS
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y

# LVGL fonts for ST7735 display (160x80 needs small fonts)
CONFIG_LV_FONT_MONTSERRAT_10=y

# Light-sleep MSPI pull-up: disabled. On ESP32-S3 this defaults on and pulls in
# octal-flash-only code in esp_hw_support/sleep_gpio.c (ESP_MSPI_IO_DQS/D4..D7),
# which does not compile for this quad-flash board under ESP-IDF 5.2.1. The
# T-Dongle is bus-powered and never light-sleeps, so this has no runtime effect.
# CONFIG_ESP_SLEEP_MSPI_NEED_ALL_IO_PU is not set

#ifndef IGATE_SECRETS_H
#define IGATE_SECRETS_H
/*
 * Local-only iGate provisioning defaults. Template — copy to igate_secrets.h and fill in (the real file is gitignored).
 *
 * These are written into NVS once, on first boot, ONLY if NVS does not already
 * hold values. After that NVS is the source of truth and can be changed at
 * runtime without rebuilding. Keep real credentials here out of git.
 */
#define IGATE_WIFI_SSID     "YOUR_WIFI_SSID"
#define IGATE_WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

/* Station callsign. Stations use an X3 prefix (X1 is for clients). Leave empty
 * to auto-derive a stable X3xxxx from the dongle's identity. */
#define IGATE_CALLSIGN      ""

#endif /* IGATE_SECRETS_H */
